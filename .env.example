# ══════════════════════════════════════════════════
# IDM LEAGUE — Environment Variables Template
# ══════════════════════════════════════════════════
# Copy this file to .env for local development
# For Vercel production, set these in Vercel Dashboard → Settings → Environment Variables

# ── Database ──────────────────────────────────────
# Local SQLite (development):
DATABASE_URL=file:/home/z/my-project/db/custom.db

# Neon PostgreSQL (production — set in Vercel Dashboard):
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# DIRECT_DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ── Auth ─────────────────────────────────────────
# 64-char hex secret (generate with: openssl rand -hex 32)
SESSION_SECRET=your-session-secret-here

# ── Admin Credentials ────────────────────────────
# First super_admin account (created on first /api/init-admin call)
ADMIN_USERNAME=idm_admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# ── Cloudinary (Image Hosting) ───────────────────
# Optional in dev, required for production image uploads
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Pusher (Real-time Events) ────────────────────
# Optional in dev, required for live match updates
NEXT_PUBLIC_PUSHER_KEY=your-pusher-key
NEXT_PUBLIC_PUSHER_CLUSTER=ap1
PUSHER_CLUSTER=ap1
PUSHER_SECRET=your-pusher-secret
PUSHER_KEY=your-pusher-key
PUSHER_APP_ID=your-pusher-app-id

# ── Frontend URL (Production Only) ───────────────
# Used for CORS and redirects in production
# FRONTEND_URL=https://your-domain.vercel.app
